{
    "id": null,
    "uid": "sms-app-metrics",
    "title": "SMS App Metrics Dashboard",
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "type": "stat",
        "title": "Total SMS Requests (Spam)",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "sms_requests_total{result=\"spam\"}"
          }
        ],
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
      },
      {
        "type": "stat",
        "title": "Total SMS Requests (Ham)",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "sms_requests_total{result=\"ham\"}"
          }
        ],
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
      },
      {
        "type": "gauge",
        "title": "Last Spam Confidence",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "sms_last_confidence{result=\"spam\"}"
          }
        ],
        "gridPos": { "h": 5, "w": 6, "x": 0, "y": 4 }
      },
      {
        "type": "gauge",
        "title": "Last Ham Confidence",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "sms_last_confidence{result=\"ham\"}"
          }
        ],
        "gridPos": { "h": 5, "w": 6, "x": 6, "y": 4 }
      },
      {
        "type": "timeseries",
        "title": "Request Duration (Histogram - rate)",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "rate(sms_request_duration_seconds_bucket[1m])"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 }
      },
      {
        "type": "timeseries",
        "title": "Avg Request Duration",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "sms_request_duration_seconds_sum / sms_request_duration_seconds_count"
          }
        ],
        "gridPos": { "h": 6, "w": 12, "x": 0, "y": 17 }
      }
    ],
    "templating": { "list": [] }
  }